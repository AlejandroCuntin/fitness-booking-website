<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Dashboard | UltraFit</title>
    <link rel="stylesheet" href="/estilos.css">
</head>

<body>

<header>
    <div id="logo">UltraFit</div>
    <nav>
        <ul>
            <li><a href="/#inicio">Inicio</a></li>
            <li><a href="/#precios">Precios</a></li>
            <li><a href="/#clases">Clases</a></li>
            <li><a href="/#ubicacion">Ubicación</a></li>
            <li><a href="/#pedirinformacion">Pedir Información</a></li>
            <li><a href="/faq">Preguntas Frecuentes</a></li>

            {{#isLoggedIn}}
                <li><a href="/dashboard">Mi Cuenta</a></li>
                <li><a href="/logout">Cerrar sesión</a></li>
            {{/isLoggedIn}}

            {{^isLoggedIn}}
                <li><a href="/login">Iniciar sesión</a></li>
            {{/isLoggedIn}}
        </ul>
    </nav>
</header>

<main>

    <section class="dashboard-hero">
        <h2>HOLA DE NUEVO,   <span class="dashboard-username">{{userMember.name}}</span>!</h2>
        <p class="dashboard-subtitle">Bienvenido a tu panel de control</p>
    </section>

    <section class="dashboard-section">
        <div class="dashboard-grid">

    <article class="dashboard-card plan-card">
        <h3>Mi Plan Actual</h3>
        <p class="dashboard-card-value">{{userMember.plan}}</p>
        <p class="dashboard-card-status">Estado: <span class="status-active">Activo</span></p>

        <form action="/plan/update" method="post" style="width:100%; margin-top: 10px;">
            <select name="plan" style="width:100%; margin-bottom: 8px;">
                <option value="Basic Plan">Basic Plan — 30€/mes</option>
                <option value="Pro Plan">Pro Plan — 50€/mes</option>
                <option value="Premium Plan">Premium Plan — 80€/mes</option>
            </select>
            <button type="submit" class="btn-outline" style="width:100%;">Cambiar Plan</button>
            {{#errorExists}}
                <p style="color:#FF6600; text-align:center; margin-top:10px; font-weight:bold;">
                    Ese nombre de usuario ya está en uso. Elige otro.
                </p>
            {{/errorExists}}
        </form>
    </article>

            <article class="dashboard-card">
                <h3>Clases Semanales</h3>
                <p class="dashboard-card-value">5</p>
                <p class="dashboard-card-label">esta semana</p>
            </article>

            <article class="dashboard-card">
                <h3>Calorías Quemadas</h3>
                <p class="dashboard-card-value">3.200</p>
                <p class="dashboard-card-label">kcal este mes</p>
            </article>

            <article class="dashboard-card qr-card">
                <h3>Club Access</h3>
                <img
                    src="https://api.qrserver.com/v1/create-qr-code/?size=130x130&data=UltraFitAccess_{{userMember.name}}"
                    alt="QR de acceso al club">
                <p class="dashboard-card-label">Muestra este QR en recepción</p>
            </article>

        </div>
    </section>

    <section class="dashboard-section">
        <div class="section-header">
            <h3>Tus Reservas</h3>
        </div>

        {{#reservations}}
        <div class="reservation-row" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
            <div>
                <strong>Reserva #{{id}}</strong> - Nivel: {{level}}
            </div>
            <div style="display: flex; gap: 20px; align-items: center;">
                <a href="/reservations/edit?id={{id}}" style="text-decoration: none;">
                    <button class="btn-edit" style="margin: 0;">Editar</button>
                </a>
                <form action="/reservations/delete" method="post" style="margin: 0;">
                    <input type="hidden" name="id" value="{{id}}">
                    <button type="submit" class="btn-delete" style="margin: 0; background-color: #e63946;">Borrar</button>
                </form>
            </div>
        </div>
        {{/reservations}}
    </section>

    <section class="dashboard-section">
        <div class="section-header">
            <h3>Nueva Reserva</h3>
        </div>

        <div class="form-card">
            <form action="/reservations/create" method="post">

                <input type="hidden" name="memberId" value="{{userMember.id}}">

                <div class="formulario_unidad">
                    <label>Entrenador</label>
                    <select name="trainerId" required>
                        <option value="">Selecciona un entrenador</option>
                        {{#trainers}}
                            <option value="{{id}}">{{name}} — {{specialty}}</option>
                        {{/trainers}}
                    </select>
                </div>

                <div class="formulario_fila" style="margin-top: 15px;">
                    <div class="formulario_unidad">
                        <label>Fecha</label>
                        <input type="date" name="date" required>
                    </div>
                    <div class="formulario_unidad">
                        <label>Hora</label>
                        <input type="time" name="time" required>
                    </div>
                </div>

                <div class="formulario_unidad" style="margin-top: 15px;">
                    <label>Nivel</label>
                    <select name="level" required>
                        <option value="Beginner">Beginner</option>
                        <option value="Intermediate">Intermediate</option>
                        <option value="Advanced">Advanced</option>
                    </select>
                </div>

                <button type="submit" style="margin-top: 20px;">Crear Reserva</button>

            </form>
        </div>
    </section>

<section class="dashboard-section" style="border-top: 1px solid #333; margin-top: 20px; padding-top: 20px;">
        <div class="section-header">
            <h3>Gestión de Entrenadores del Club Seccion Ficticia que no estaria en la real. Solo esta de prueba</h3>
        </div>

        {{#trainers}}
        <div class="reservation-row">
            <div class="reservation-info">
                <span class="reservation-date" style="color: #ff6600; font-weight: bold;">{{name}}</span>
                <span class="reservation-time">Especialidad: {{specialty}}</span>
                <span class="reservation-level">Experiencia: {{experienceYears}} años</span>
            </div>
            <div class="reservation-actions" style="flex-direction: row; gap: 10px;">
                <a href="/trainers/edit?id={{id}}">
                    <button class="btn-edit" style="background-color: #444;">Editar</button>
                </a>
                <form action="/trainers/delete" method="post" style="margin: 0;">
                    <input type="hidden" name="id" value="{{id}}">
                    <button type="submit" class="btn-delete" style="background-color: #e63946;">Borrar</button>
                </form>
            </div>
        </div>
        {{/trainers}}

        <div class="form-card" style="margin-top: 20px; background-color: #222; padding: 15px; border-radius: 8px;">
            <h4 style="margin-bottom: 10px; color: #ccc;">Dar de alta un nuevo entrenador</h4>
            <form action="/trainers/create" method="post">
                <div class="formulario_fila">
                    <div class="formulario_unidad">
                        <input type="text" name="name" placeholder="Nombre del entrenador" required>
                    </div>
                    <div class="formulario_unidad">
                        <input type="text" name="specialty" placeholder="Especialidad (ej. Yoga)" required>
                    </div>
                    <div class="formulario_unidad">
                        <input type="number" name="experienceYears" placeholder="Años de exp." required>
                    </div>
                </div>
                <button type="submit" style="margin-top: 10px; width: 100%;">Añadir Entrenador</button>
            </form>
        </div>
    </section>

    <section class="dashboard-section">
        <div class="section-header">
            <h3>Editar Mis Datos Personales</h3>
        </div>
        <div class="form-card">
            <form action="/member/update" method="post">
                <div class="formulario_fila">
                    <div class="formulario_unidad">
                        <label>Nombre</label>
                        <input type="text" name="name" value="{{userMember.name}}" required>
                    </div>
                    <div class="formulario_unidad">
                        <label>Apellidos</label>
                        <input type="text" name="surname" value="{{userMember.surname}}">
                    </div>
                </div>
                <div class="formulario_fila">
                    <div class="formulario_unidad">
                        <label>Email</label>
                        <input type="email" name="email" value="{{userMember.email}}">
                    </div>
                    <div class="formulario_unidad">
                        <label>Teléfono</label>
                        <input type="text" name="phone" value="{{userMember.phone}}">
                    </div>
                </div>
                <button type="submit" style="margin-top: 15px;">Actualizar Perfil</button>
            </form>
        </div>
    </section>

    <section class="dashboard-section" style="text-align: center; margin-top: 40px; border-top: 1px solid #333; padding-top: 20px;">
        <h3 style="color: #e63946;">Zona de Peligro</h3>
        <p style="color: #aaa; margin-bottom: 15px;">Si eliminas tu cuenta, perderás todas tus reservas y datos.</p>
        <form action="/account/delete" method="post" onsubmit="return confirm('¿Estás completamente seguro de que quieres eliminar tu cuenta? Esta acción no se puede deshacer.');">
            <button type="submit" style="background-color: #e63946; color: white;">Eliminar mi cuenta</button>
        </form>
    </section>



</main>

<footer>
    <div class="footer_inferior">
        <p>&copy; 2024 UltraFit. Todos los derechos reservados.</p>
    </div>
</footer>

<script src="/app.js"></script>
</body>
</html>